# MongoDB connection (Atlas or local). Used by Better Auth and the books catalog.
MONGODB_URI=mongodb+srv://USER:PASS@cluster.example.mongodb.net/?retryWrites=true&w=majority

# Optional: database name (default: online_book_borrowing)
# MONGODB_DB_NAME=online_book_borrowing

# Better Auth — use a long random string in production (32+ characters).
# Generate: npx auth secret   or   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL of the app (no trailing slash). Required in production for OAuth callbacks.
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (optional — leave unset to disable Google sign-in)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
